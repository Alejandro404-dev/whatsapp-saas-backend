generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. TENANT (La empresa o cliente)
model Tenant {
  id        String   @id @default(uuid())
  name      String
  status    Boolean  @default(true)
  users     User[]
  roles     Role[]   // NUEVO: La empresa ahora es dueña de sus propios roles
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. ROLE (Los roles del sistema: Admin, Agente, etc.)
model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions String[] @default([]) // NUEVO: Lista de permisos (Ej: ["ver_dashboard", "crear_flujos"])
  isSystem    Boolean  @default(false) // NUEVO: Blindaje para SuperAdmin y Admin
  
  // Relación con el Tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  users       User[]

  // MAGIA SAAS: El nombre del rol es único, pero SOLO dentro de su misma empresa
  @@unique([name, tenantId])
}

// 3. USER (Los usuarios que acceden al sistema)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Aquí guardaremos la contraseña encriptada
  
  // Relaciones
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String

  isActive  Boolean  @default(true) // NUEVO: Control de bloqueo de acceso

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. MENU (Los accesos a la plataforma según el rol)
model Menu {
  id        String   @id @default(uuid())
  name      String   // Ej: "Constructor de Flujos"
  path      String   // Ej: "/dashboard/flujos"
  icon      String?
  isActive  Boolean  @default(true)
}