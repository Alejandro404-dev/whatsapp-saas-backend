generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. TENANT (La empresa o cliente)
model Tenant {
  id        String   @id @default(uuid())
  name      String
  status    Boolean  @default(true)
  users     User[]
  roles     Role[]   
  

  campaigns Campaign[] 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. ROLE (Los roles del sistema: Admin, Agente, etc.)
model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions String[] @default([]) 
  isSystem    Boolean  @default(false) 
  
  // Relación con el Tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  users       User[]

  // El nombre del rol es único por empresa
  @@unique([name, tenantId])
}

// 3. USER (Los usuarios que acceden al sistema)
model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  password              String   
  
  // Relaciones
  tenant                Tenant   @relation(fields: [tenantId], references: [id])
  tenantId              String
  
  role                  Role     @relation(fields: [roleId], references: [id])
  roleId                String

  isActive              Boolean  @default(true) 
  
  // ==========================================
  // NUEVO: FLAG DE SEGURIDAD
  // ==========================================
  requirePasswordChange Boolean  @default(false) 

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// 4. MENU (Los accesos a la plataforma según el rol)
model Menu {
  id        String   @id @default(uuid())
  name      String   
  path      String   
  icon      String?
  isActive  Boolean  @default(true)
}

// 5. CICLO DE VIDA DE CAMPAIGN 
model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  // Rango de fechas
  startDate   DateTime
  endDate     DateTime
  
  // Estado para saber si está activa, pausada o expirada
  status      String   @default("ACTIVA") // Ej: "ACTIVA", "EXPIRADA", "PAUSADA"
  
  // Relación obligatoria con la empresa (Tenant)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}